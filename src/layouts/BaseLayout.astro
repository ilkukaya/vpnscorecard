---
import { getLangFromUrl, getAlternateLinks, type Lang, defaultLang } from '../i18n/index';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schemaMarkup?: string;
  lang?: Lang;
}

const { title, description, canonical, ogImage = '/og-image.png', schemaMarkup, lang: propLang } = Astro.props;
const lang = propLang || getLangFromUrl(Astro.url);
const canonicalUrl = canonical || Astro.url?.href || 'https://vpnscorecard.com';
const alternateLinks = getAlternateLinks(Astro.url.pathname);
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Alternate Language Links -->
    {alternateLinks.map(({ lang: altLang, href }) => (
      <link rel="alternate" hreflang={altLang} href={`https://vpnscorecard.com${href}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`https://vpnscorecard.com${alternateLinks.find(l => l.lang === 'en')?.href || '/'}`} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : lang === 'tr' ? 'tr_TR' : 'en_US'} />
    <meta property="og:site_name" content="VPNScorecard" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <meta name="theme-color" content="#1a1f36" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <script defer src="https://plausible.io/js/script.js" data-domain="vpnscorecard.com"></script>
    {schemaMarkup && <Fragment set:html={schemaMarkup} />}
  </head>
  <body class="bg-slate-50 font-sans text-gray-900 antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-brand-dark focus:text-white focus:px-4 focus:py-2 focus:rounded">
      Skip to main content
    </a>
    <slot name="header" />
    <main id="main-content" class="min-h-screen">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
