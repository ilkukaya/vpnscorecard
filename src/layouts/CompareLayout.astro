---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import CTAButton from '../components/CTAButton.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { getPricing } from '../lib/vpnData';
import { getBestAffiliateLink } from '../lib/affiliateLinks';
import { formatPrice, getBestPrice } from '../lib/formatters';
import { type Lang, defaultLang, t, getLocalizedPath } from '../i18n/index';

interface Props {
  vpn1: any;
  vpn2: any;
  customFaq?: { question: string; answer: string }[];
  lang?: Lang;
}

const { vpn1, vpn2, customFaq, lang = defaultLang } = Astro.props;
const pricing1 = getPricing(vpn1.id);
const pricing2 = getPricing(vpn2.id);
const link1 = getBestAffiliateLink(vpn1, 'compare');
const link2 = getBestAffiliateLink(vpn2, 'compare');
const winner = vpn1.scores.total >= vpn2.scores.total ? vpn1 : vpn2;
const loser = winner === vpn1 ? vpn2 : vpn1;
const best1 = getBestPrice(pricing1);
const best2 = getBestPrice(pricing2);

function getSpeed(vpn: any): number {
  const st = vpn.speed_tests;
  if (!st) return 0;
  return st.nordlynx?.download_mbps || st.lightway?.download_mbps || st.wireguard?.download_mbps || st.hydra?.download_mbps || 0;
}

const speed1 = getSpeed(vpn1);
const speed2 = getSpeed(vpn2);

const title = `${vpn1.name} vs ${vpn2.name} 2026: Which is Better? [Speed Tested] | VPNScorecard`;
const description = `${winner.name} wins with ${winner.scores.total}/100 vs ${loser.scores.total}/100. Speed: ${speed1} vs ${speed2} Mbps. Price: ${best1 ? formatPrice(best1.price) : 'N/A'} vs ${best2 ? formatPrice(best2.price) : 'N/A'}/mo. Full comparison inside.`;

const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": `${vpn1.name} vs ${vpn2.name}: Which VPN is Better in 2026?`,
  "author": { "@type": "Organization", "name": "VPNScorecard" },
  "publisher": { "@type": "Organization", "name": "VPNScorecard", "url": "https://vpnscorecard.com" },
  "datePublished": "2026-04-01",
  "dateModified": "2026-04-01"
});

const faqData = customFaq || [
  {
    question: `Is ${vpn1.name} better than ${vpn2.name}?`,
    answer: `${winner.name} scores ${winner.scores.total}/100 vs ${loser.scores.total}/100 in our testing. ${winner.name} is the better overall choice for most users.`
  },
  {
    question: `Which is faster: ${vpn1.name} or ${vpn2.name}?`,
    answer: speed1 > speed2
      ? `${vpn1.name} is faster at ${speed1} Mbps vs ${vpn2.name}'s ${speed2} Mbps in our March 2026 tests.`
      : `${vpn2.name} is faster at ${speed2} Mbps vs ${vpn1.name}'s ${speed1} Mbps in our March 2026 tests.`
  },
  {
    question: `Which is cheaper?`,
    answer: best1 && best2
      ? best1.price < best2.price
        ? `${vpn1.name} is cheaper at ${formatPrice(best1.price)}/mo vs ${vpn2.name}'s ${formatPrice(best2.price)}/mo.`
        : `${vpn2.name} is cheaper at ${formatPrice(best2.price)}/mo vs ${vpn1.name}'s ${formatPrice(best1.price)}/mo.`
      : 'Check both websites for current pricing.'
  },
  {
    question: `Do both work with Netflix?`,
    answer: vpn1.streaming.netflix_us && vpn2.streaming.netflix_us
      ? `Yes, both ${vpn1.name} and ${vpn2.name} reliably unblock Netflix US in our testing.`
      : vpn1.streaming.netflix_us
        ? `${vpn1.name} works with Netflix US, but ${vpn2.name} has limited support.`
        : vpn2.streaming.netflix_us
          ? `${vpn2.name} works with Netflix US, but ${vpn1.name} has limited support.`
          : `Neither VPN reliably unblocks Netflix in our testing. Consider NordVPN or ExpressVPN instead.`
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqData.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": { "@type": "Answer", "text": faq.answer }
  }))
};
---

<BaseLayout title={title} description={description} lang={lang} schemaMarkup={`<script type="application/ld+json">${schemaMarkup}</script>\n<script type="application/ld+json">${JSON.stringify(faqSchema)}</script>`}>
  <Header slot="header" lang={lang} />
  <AffiliateDisclosure lang={lang} />

  <div class="max-w-5xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-6">
      <ol class="flex items-center gap-1">
        <li><a href={getLocalizedPath('/', lang)} class="hover:text-brand">{t(lang, 'nav.home')}</a></li>
        <li><span class="mx-1">/</span></li>
        <li><a href={getLocalizedPath('/compare/', lang)} class="hover:text-brand">{t(lang, 'nav.compare')}</a></li>
        <li><span class="mx-1">/</span></li>
        <li class="text-gray-700">{vpn1.name} vs {vpn2.name}</li>
      </ol>
    </nav>

    <h1 class="text-3xl md:text-4xl font-bold text-brand-dark mb-2">{t(lang, 'compare.title', { vpn1: vpn1.name, vpn2: vpn2.name, year: '2026' })}</h1>
    <p class="text-gray-600 mb-8">{t(lang, 'compare.subtitle')}</p>

    <div class="bg-green-50 border border-green-200 rounded-xl p-6 mb-8">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-2xl">🏆</span>
        <h2 class="text-xl font-bold text-green-800">Winner: {winner.name} ({winner.scores.total}/100)</h2>
      </div>
      <p class="text-green-700">
        For most users, {winner.name} offers better overall value with a score of {winner.scores.total}/100 vs {loser.scores.total}/100.
        {loser.name} wins on: {loser.scores.privacy > winner.scores.privacy ? 'privacy' : ''}{loser.scores.speed > winner.scores.speed ? 'speed' : ''}{loser.scores.ease_of_use > winner.scores.ease_of_use ? ' ease of use' : ''}{loser.scores.value > winner.scores.value ? ' value' : ''}.
      </p>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-8">
      <h2 class="text-xl font-bold text-brand-dark mb-6">{t(lang, 'compare.headToHead')}</h2>
      <ComparisonTable vpns={[vpn1, vpn2]} pricing={{ [vpn1.id]: pricing1, [vpn2.id]: pricing2 }} pageType="compare" lang={lang} />
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <div class="flex items-center gap-3 mb-3">
          <img src={vpn1.logo} alt={vpn1.name} class="w-8 h-8 object-contain" />
          <h3 class="text-lg font-bold text-brand-dark">{t(lang, 'compare.choose', { vpn: vpn1.name })}</h3>
        </div>
        <ul class="space-y-2 text-gray-700 mb-4">
          {vpn1.pros.slice(0, 4).map((pro: string) => (
            <li class="flex gap-2"><span class="text-green-500 flex-shrink-0">✓</span> {pro}</li>
          ))}
        </ul>
        {best1 && <p class="text-lg font-bold text-brand-dark mb-3">From {formatPrice(best1.price)}/mo {best1.savings ? `(${best1.savings}% off)` : ''}</p>}
        <CTAButton href={link1} vpnId={vpn1.id} pageType="compare" variant="primary" size="md" fullWidth>{t(lang, 'vpnCard.get', { vpn: vpn1.name })}</CTAButton>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <div class="flex items-center gap-3 mb-3">
          <img src={vpn2.logo} alt={vpn2.name} class="w-8 h-8 object-contain" />
          <h3 class="text-lg font-bold text-brand-dark">{t(lang, 'compare.choose', { vpn: vpn2.name })}</h3>
        </div>
        <ul class="space-y-2 text-gray-700 mb-4">
          {vpn2.pros.slice(0, 4).map((pro: string) => (
            <li class="flex gap-2"><span class="text-green-500 flex-shrink-0">✓</span> {pro}</li>
          ))}
        </ul>
        {best2 && <p class="text-lg font-bold text-brand-dark mb-3">From {formatPrice(best2.price)}/mo {best2.savings ? `(${best2.savings}% off)` : ''}</p>}
        <CTAButton href={link2} vpnId={vpn2.id} pageType="compare" variant="primary" size="md" fullWidth>{t(lang, 'vpnCard.get', { vpn: vpn2.name })}</CTAButton>
      </div>
    </div>

    <div class="mb-8">
      <h2 class="text-xl font-bold text-brand-dark mb-4">{t(lang, 'review.faq')}</h2>
      <FAQAccordion questions={faqData} />
    </div>
  </div>

  <Footer slot="footer" lang={lang} />
</BaseLayout>
