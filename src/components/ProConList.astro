---
import { type Lang, defaultLang, t } from '../i18n/index';

interface Props {
  pros: string[];
  cons: string[];
  lang?: Lang;
}

const { pros, cons, lang = defaultLang } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  <div>
    <h3 class="text-lg font-bold text-green-700 mb-3 flex items-center gap-2">
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
      {t(lang, 'review.pros')}
    </h3>
    <ul class="space-y-2">
      {pros.map((pro) => (
        <li class="flex items-start gap-2 text-gray-700">
          <span class="text-green-500 mt-0.5 flex-shrink-0">✓</span>
          <span class="text-sm">{pro}</span>
        </li>
      ))}
    </ul>
  </div>
  <div>
    <h3 class="text-lg font-bold text-red-700 mb-3 flex items-center gap-2">
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
      {t(lang, 'review.cons')}
    </h3>
    <ul class="space-y-2">
      {cons.map((con) => (
        <li class="flex items-start gap-2 text-gray-700">
          <span class="text-red-500 mt-0.5 flex-shrink-0">✗</span>
          <span class="text-sm">{con}</span>
        </li>
      ))}
    </ul>
  </div>
</div>
