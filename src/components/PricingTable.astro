---
import { getBestAffiliateLink } from '../lib/affiliateLinks';
import { formatPrice } from '../lib/formatters';
import { getVPNById } from '../lib/vpnData';

interface Props {
  pricing: any;
  vpnId: string;
  vpnName: string;
  pageType?: string;
}

const { pricing, vpnId, vpnName, pageType = 'review' } = Astro.props;
const vpn = getVPNById(vpnId);
const affiliateLink = getBestAffiliateLink(vpn || { id: vpnId, website: '#' }, pageType);

const plans: any[] = [];
if (pricing.monthly) plans.push({ ...pricing.monthly, key: 'monthly', label: 'Monthly', popular: false });
if (pricing.six_month) plans.push({ ...pricing.six_month, key: 'six_month', label: '6 Months', popular: false });
if (pricing.yearly) plans.push({ ...pricing.yearly, key: 'yearly', label: '1 Year', popular: !pricing.two_year && !pricing.three_year });
if (pricing.two_year) plans.push({ ...pricing.two_year, key: 'two_year', label: '2 Years', popular: true });
if (pricing.three_year) plans.push({ ...pricing.three_year, key: 'three_year', label: '3 Years', popular: true });
if (pricing.five_year) plans.push({ ...pricing.five_year, key: 'five_year', label: '5 Years', popular: true });
---

<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
  {plans.map((plan) => (
    <div class={`relative bg-white rounded-xl border-2 ${plan.popular ? 'border-brand shadow-md' : 'border-gray-200'} p-6`}>
      {plan.popular && (
        <div class="absolute -top-3 left-1/2 -translate-x-1/2">
          <span class="bg-brand text-white text-xs font-bold px-3 py-1 rounded-full">Best Value</span>
        </div>
      )}
      <h3 class="text-lg font-bold text-brand-dark mb-2">{plan.label}</h3>
      <div class="mb-4">
        <span class="text-3xl font-bold text-brand-dark">{formatPrice(plan.price, pricing.currency || 'USD')}</span>
        <span class="text-gray-500">/mo</span>
      </div>
      {plan.total && (
        <p class="text-sm text-gray-500 mb-2">Billed {formatPrice(plan.total, pricing.currency || 'USD')} total</p>
      )}
      {plan.savings_percent && (
        <p class="text-sm text-green-600 font-medium mb-4">Save {plan.savings_percent}%</p>
      )}
      <a
        href={affiliateLink}
        rel="nofollow noopener sponsored"
        target="_blank"
        class={`block w-full text-center py-2.5 rounded-lg font-semibold transition-colors duration-200 ${plan.popular ? 'bg-brand hover:bg-brand-dark text-white' : 'bg-gray-100 hover:bg-gray-200 text-gray-700'}`}
      >
        Get {vpnName}
      </a>
    </div>
  ))}
</div>

{pricing.refund_days > 0 && (
  <p class="text-sm text-gray-500 mt-4 text-center">{pricing.refund_days}-day money-back guarantee</p>
)}
