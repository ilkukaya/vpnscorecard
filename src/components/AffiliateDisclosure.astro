---
import { type Lang, defaultLang, t, getLocalizedPath } from '../i18n/index';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
---

<div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-8">
  <div class="flex items-start gap-3">
    <svg class="w-5 h-5 text-amber-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
      <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
    </svg>
    <div>
      <p class="text-sm text-amber-800 font-medium">{t(lang, 'disclosure.text').split('.')[0]}.</p>
      <p class="text-sm text-amber-700 mt-1">{t(lang, 'disclosure.text')} <a href={getLocalizedPath('/methodology', lang)} class="underline font-medium">{t(lang, 'disclosure.learnMore')}</a>.</p>
    </div>
  </div>
</div>
