---
import { buildAffiliateLink } from '../lib/affiliateLinks';

interface Props {
  href: string;
  vpnId: string;
  pageType: string;
  variant?: 'primary' | 'secondary' | 'light' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  fullWidth?: boolean;
}

const { href, vpnId, pageType, variant = 'primary', size = 'md', fullWidth = false } = Astro.props;
const trackedHref = buildAffiliateLink(href, { vpnId, pageType });

const variantClasses: Record<string, string> = {
  primary: 'bg-brand hover:bg-brand-dark text-white',
  secondary: 'bg-green-600 hover:bg-green-700 text-white',
  light: 'bg-white hover:bg-gray-100 text-brand-dark',
  outline: 'border-2 border-brand text-brand hover:bg-brand hover:text-white',
};

const sizeClasses: Record<string, string> = {
  sm: 'px-3 py-1.5 text-sm',
  md: 'px-5 py-2.5 text-sm',
  lg: 'px-8 py-3.5 text-base',
};
---

<a
  href={trackedHref}
  rel="nofollow noopener sponsored"
  target="_blank"
  class="inline-flex items-center justify-center font-semibold rounded-lg transition-colors duration-200 {variantClasses[variant]} {sizeClasses[size]} {fullWidth ? 'w-full' : ''}"
>
  <slot />
  <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
</a>
