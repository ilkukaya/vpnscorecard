---
import { type Lang, defaultLang, t, getLocalizedPath } from '../i18n/index';

interface Props {
  vpnId?: string;
  lang?: Lang;
}

const { vpnId, lang = defaultLang } = Astro.props;
---

<div class="flex items-center gap-4 text-xs text-gray-500 flex-wrap">
  <span class="inline-flex items-center gap-1">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
    {t(lang, 'trust.labTested')}
  </span>
  <span class="inline-flex items-center gap-1">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
    {t(lang, 'trust.updatedMonthly')}
  </span>
  <span class="inline-flex items-center gap-1">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
    {t(lang, 'trust.noPaidRankings')}
  </span>
  <a href={getLocalizedPath('/methodology', lang)} class="inline-flex items-center gap-1 text-brand hover:underline">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    {t(lang, 'nav.methodology')}
  </a>
</div>
