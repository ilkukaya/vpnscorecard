---
---

<header class="bg-brand-dark border-b border-gray-800 sticky top-0 z-40">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2">
        <svg class="w-8 h-8 text-brand-light" viewBox="0 0 32 32" fill="currentColor">
          <rect x="2" y="8" width="28" height="18" rx="2" fill="none" stroke="currentColor" stroke-width="2"/>
          <line x1="2" y1="14" x2="30" y2="14" stroke="currentColor" stroke-width="2"/>
          <line x1="12" y1="8" x2="12" y2="26" stroke="currentColor" stroke-width="2"/>
          <circle cx="7" cy="20" r="2" fill="currentColor"/>
          <rect x="16" y="17" width="4" height="6" rx="0.5" fill="currentColor" opacity="0.6"/>
          <rect x="22" y="15" width="4" height="8" rx="0.5" fill="currentColor" opacity="0.4"/>
        </svg>
        <span class="text-xl font-bold text-white">VPN<span class="text-brand-light">Scorecard</span></span>
      </a>

      <nav class="hidden md:flex items-center gap-6" aria-label="Main navigation">
        <a href="/" class="text-gray-300 hover:text-white text-sm font-medium transition-colors">Home</a>
        <a href="/reviews/" class="text-gray-300 hover:text-white text-sm font-medium transition-colors">Reviews</a>
        <a href="/compare/" class="text-gray-300 hover:text-white text-sm font-medium transition-colors">Compare</a>
        <a href="/deals" class="text-gray-300 hover:text-white text-sm font-medium transition-colors">Deals</a>
        <a href="/quiz" class="text-gray-300 hover:text-white text-sm font-medium transition-colors">Quiz</a>
        <a href="/methodology" class="text-gray-300 hover:text-white text-sm font-medium transition-colors">Methodology</a>
      </nav>

      <div class="flex items-center gap-3">
        <a href="/deals" class="hidden sm:inline-flex items-center px-4 py-2 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold rounded-lg transition-colors">
          Best Deals
        </a>
        <button id="mobile-menu-btn" class="md:hidden p-2 text-gray-300 hover:text-white" aria-label="Toggle menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>

    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <nav class="flex flex-col gap-2" aria-label="Mobile navigation">
        <a href="/" class="text-gray-300 hover:text-white text-sm font-medium py-2 transition-colors">Home</a>
        <a href="/reviews/" class="text-gray-300 hover:text-white text-sm font-medium py-2 transition-colors">Reviews</a>
        <a href="/compare/" class="text-gray-300 hover:text-white text-sm font-medium py-2 transition-colors">Compare</a>
        <a href="/deals" class="text-gray-300 hover:text-white text-sm font-medium py-2 transition-colors">Deals</a>
        <a href="/quiz" class="text-gray-300 hover:text-white text-sm font-medium py-2 transition-colors">Quiz</a>
        <a href="/methodology" class="text-gray-300 hover:text-white text-sm font-medium py-2 transition-colors">Methodology</a>
      </nav>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>
