---
import { languages, type Lang, defaultLang, getLocalizedPath } from '../i18n/index';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const currentPath = Astro.url.pathname;
---

<header class="bg-brand-dark border-b border-gray-800 sticky top-0 z-40">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <a href={getLocalizedPath('/', lang)} class="flex items-center gap-2">
        <svg class="w-8 h-8 text-brand-light" viewBox="0 0 32 32" fill="currentColor">
          <rect x="2" y="8" width="28" height="18" rx="2" fill="none" stroke="currentColor" stroke-width="2"/>
          <line x1="2" y1="14" x2="30" y2="14" stroke="currentColor" stroke-width="2"/>
          <line x1="12" y1="8" x2="12" y2="26" stroke="currentColor" stroke-width="2"/>
          <circle cx="7" cy="20" r="2" fill="currentColor"/>
          <rect x="16" y="17" width="4" height="6" rx="0.5" fill="currentColor" opacity="0.6"/>
          <rect x="22" y="15" width="4" height="8" rx="0.5" fill="currentColor" opacity="0.4"/>
        </svg>
        <span class="text-xl font-bold text-white">VPN<span class="text-brand-light">Scorecard</span></span>
      </a>

      <nav class="hidden md:flex items-center gap-6" aria-label="Main navigation">
        <a href={getLocalizedPath('/', lang)} class="text-gray-300 hover:text-white text-sm font-medium transition-colors">Home</a>
        <a href={getLocalizedPath('/reviews/', lang)} class="text-gray-300 hover:text-white text-sm font-medium transition-colors">Reviews</a>
        <a href={getLocalizedPath('/compare/', lang)} class="text-gray-300 hover:text-white text-sm font-medium transition-colors">Compare</a>
        <a href={getLocalizedPath('/deals', lang)} class="text-gray-300 hover:text-white text-sm font-medium transition-colors">Deals</a>
        <a href={getLocalizedPath('/quiz', lang)} class="text-gray-300 hover:text-white text-sm font-medium transition-colors">Quiz</a>
        <a href={getLocalizedPath('/methodology', lang)} class="text-gray-300 hover:text-white text-sm font-medium transition-colors">Methodology</a>
      </nav>

      <div class="flex items-center gap-3">
        <!-- Language Switcher -->
        <div class="relative" id="lang-switcher">
          <button
            id="lang-btn"
            class="flex items-center gap-1.5 px-2.5 py-1.5 text-gray-300 hover:text-white text-sm font-medium transition-colors rounded-lg hover:bg-white/10"
            aria-label="Change language"
            aria-expanded="false"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
            </svg>
            <span class="hidden sm:inline">{languages[lang].label}</span>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div id="lang-dropdown" class="hidden absolute right-0 top-full mt-1 bg-white rounded-lg shadow-lg border border-gray-200 py-1 min-w-[140px] z-50">
            {Object.entries(languages).map(([code, { label, flag }]) => {
              const cleanPath = currentPath.replace(/^\/(en|es|tr)/, '') || '/';
              const href = code === 'en' ? cleanPath : `/${code}${cleanPath}`;
              return (
                <a
                  href={href}
                  class={`flex items-center gap-2 px-3 py-2 text-sm hover:bg-gray-100 transition-colors ${code === lang ? 'text-brand font-semibold bg-blue-50' : 'text-gray-700'}`}
                >
                  <span>{flag}</span>
                  <span>{label}</span>
                </a>
              );
            })}
          </div>
        </div>

        <a href={getLocalizedPath('/deals', lang)} class="hidden sm:inline-flex items-center px-4 py-2 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold rounded-lg transition-colors">
          Best Deals
        </a>
        <button id="mobile-menu-btn" class="md:hidden p-2 text-gray-300 hover:text-white" aria-label="Toggle menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>

    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <nav class="flex flex-col gap-2" aria-label="Mobile navigation">
        <a href={getLocalizedPath('/', lang)} class="text-gray-300 hover:text-white text-sm font-medium py-2 transition-colors">Home</a>
        <a href={getLocalizedPath('/reviews/', lang)} class="text-gray-300 hover:text-white text-sm font-medium py-2 transition-colors">Reviews</a>
        <a href={getLocalizedPath('/compare/', lang)} class="text-gray-300 hover:text-white text-sm font-medium py-2 transition-colors">Compare</a>
        <a href={getLocalizedPath('/deals', lang)} class="text-gray-300 hover:text-white text-sm font-medium py-2 transition-colors">Deals</a>
        <a href={getLocalizedPath('/quiz', lang)} class="text-gray-300 hover:text-white text-sm font-medium py-2 transition-colors">Quiz</a>
        <a href={getLocalizedPath('/methodology', lang)} class="text-gray-300 hover:text-white text-sm font-medium py-2 transition-colors">Methodology</a>
        <div class="flex gap-2 pt-2 border-t border-gray-700">
          {Object.entries(languages).map(([code, { label, flag }]) => {
            const cleanPath = currentPath.replace(/^\/(en|es|tr)/, '') || '/';
            const href = code === 'en' ? cleanPath : `/${code}${cleanPath}`;
            return (
              <a
                href={href}
                class={`flex items-center gap-1 px-3 py-1.5 rounded-lg text-sm ${code === lang ? 'bg-brand text-white' : 'bg-gray-700 text-gray-300 hover:text-white'}`}
              >
                <span>{flag}</span>
                <span>{label}</span>
              </a>
            );
          })}
        </div>
      </nav>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }

  const langBtn = document.getElementById('lang-btn');
  const langDropdown = document.getElementById('lang-dropdown');
  if (langBtn && langDropdown) {
    langBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      langDropdown.classList.toggle('hidden');
      langBtn.setAttribute('aria-expanded', langDropdown.classList.contains('hidden') ? 'false' : 'true');
    });
    document.addEventListener('click', () => {
      langDropdown.classList.add('hidden');
      langBtn.setAttribute('aria-expanded', 'false');
    });
  }
</script>
