---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import QuizWidget from '../components/QuizWidget';

const title = 'Which VPN is Right for You? Take the Quiz | VPNScorecard';
const description = 'Answer 5 quick questions and we\'ll recommend the best VPN for your needs.';
---
<BaseLayout title={title} description={description}>
  <Header slot="header" />
  <div class="max-w-2xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-brand-dark mb-2 text-center">Which VPN is Right for You?</h1>
    <p class="text-gray-600 mb-8 text-center">Answer 5 quick questions and we'll recommend the perfect VPN.</p>
    <QuizWidget client:load />
  </div>
  <Footer slot="footer" />
</BaseLayout>
