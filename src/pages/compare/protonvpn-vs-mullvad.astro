---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTAButton from '../../components/CTAButton.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import { getVPNBySlug, getPricing } from '../../lib/vpnData';
import { getBestAffiliateLink } from '../../lib/affiliateLinks';

const vpn1 = getVPNBySlug('protonvpn');
const vpn2 = getVPNBySlug('mullvad');
const pricing1 = getPricing('protonvpn');
const pricing2 = getPricing('mullvad');
const link1 = getBestAffiliateLink(vpn1, 'compare');
const link2 = vpn2.website;
const title = 'Proton VPN vs Mullvad 2026: Best Privacy VPN?';
const description = 'Both are privacy-focused VPNs. Proton VPN has a free tier. Mullvad has anonymous accounts.';
---
<BaseLayout title={title} description={description}>
  <Header slot="header" />
  <AffiliateDisclosure />
  <div class="max-w-5xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-6"><ol class="flex items-center gap-1"><li><a href="/" class="hover:text-brand">Home</a></li><li><span class="mx-1">/</span></li><li><a href="/compare/" class="hover:text-brand">Compare</a></li><li><span class="mx-1">/</span></li><li class="text-gray-700">Proton VPN vs Mullvad</li></ol></nav>
    <h1 class="text-3xl md:text-4xl font-bold text-brand-dark mb-2">Proton VPN vs Mullvad: Best Privacy VPN?</h1>
    <p class="text-gray-600 mb-8">Two privacy-first VPNs. Different approaches to anonymity.</p>
    <div class="bg-green-50 border border-green-200 rounded-xl p-6 mb-8">
      <div class="flex items-center gap-3 mb-2"><span class="text-2xl">🏆</span><h2 class="text-xl font-bold text-green-800">Winner: {vpn1.ad} ({vpn1.puanlar.toplam} vs {vpn2.puanlar.toplam})</h2></div>
      <p class="text-green-700">{vpn1.ad} wins for most users with its free tier and streaming support. {vpn2.ad} wins for maximum anonymity.</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-8">
      <ComparisonTable vpns={[vpn1, vpn2]} pricing={{ protonvpn: pricing1, mullvad: pricing2 }} pageType="compare" />
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h3 class="text-lg font-bold text-brand-dark mb-3">Choose {vpn1.ad} if:</h3>
        <ul class="space-y-2 text-gray-700">
          <li class="flex gap-2"><span class="text-green-500">✓</span> You want a free tier</li>
          <li class="flex gap-2"><span class="text-green-500">✓</span> You need streaming support</li>
          <li class="flex gap-2"><span class="text-green-500">✓</span> You want Tor over VPN</li>
        </ul>
        <CTAButton href={link1} vpnId={vpn1.id} pageType="compare" variant="primary" size="md" class="mt-4" fullWidth>Get {vpn1.ad}</CTAButton>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h3 class="text-lg font-bold text-brand-dark mb-3">Choose {vpn2.ad} if:</h3>
        <ul class="space-y-2 text-gray-700">
          <li class="flex gap-2"><span class="text-green-500">✓</span> You want anonymous accounts (no email)</li>
          <li class="flex gap-2"><span class="text-green-500">✓</span> You want cash payments</li>
          <li class="flex gap-2"><span class="text-green-500">✓</span> You want the fastest WireGuard speeds</li>
        </ul>
        <a href={link2} rel="nofollow noopener sponsored" target="_blank" class="block w-full text-center py-2.5 rounded-lg font-semibold bg-brand hover:bg-brand-dark text-white transition-colors">Visit {vpn2.ad}</a>
      </div>
    </div>
    <FAQAccordion questions={[
      { question: 'Which is more private?', answer: 'Mullvad edges out Proton VPN for pure anonymity — no email required, cash payments, and account numbers instead of usernames. Proton VPN is excellent but requires an email for the free tier.' },
      { question: 'Which is faster?', answer: 'Mullvad (912 Mbps) is the fastest VPN we tested, beating Proton VPN (689 Mbps).' },
      { question: 'Can either unblock Netflix?', answer: 'Proton VPN can unblock Netflix. Mullvad cannot — it does not focus on streaming at all.' },
    ]} />
  </div>
  <Footer slot="footer" />
</BaseLayout>
