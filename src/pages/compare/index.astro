---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getVPNsForComparison } from '../../lib/vpnData';

const vpns = getVPNsForComparison();
const title = 'Compare VPNs Side by Side — VPNScorecard';
const description = 'Compare any two VPNs side by side. Speed, privacy, pricing, and features.';
---
<BaseLayout title={title} description={description}>
  <Header slot="header" />
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-brand-dark mb-2">Compare VPNs</h1>
    <p class="text-gray-600 mb-8">Choose two VPNs to compare side by side.</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
      {vpns.map((vpn) => (
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 flex items-center gap-4">
          <img src={`/logos/${vpn.slug}.svg`} alt={vpn.ad} class="w-10 h-10 object-contain" loading="lazy" />
          <div class="flex-1">
            <h3 class="font-bold text-brand-dark">{vpn.ad}</h3>
            <p class="text-sm text-gray-500">{vpn.puanlar.toplam}/100</p>
          </div>
        </div>
      ))}
    </div>
    <h2 class="text-xl font-bold text-brand-dark mb-4">Popular Comparisons</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <a href="/compare/nordvpn-vs-expressvpn" class="block bg-white rounded-xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition-shadow">
        <h3 class="font-bold text-brand-dark">NordVPN vs ExpressVPN</h3>
        <p class="text-sm text-gray-500 mt-1">The most searched VPN comparison</p>
      </a>
      <a href="/compare/nordvpn-vs-surfshark" class="block bg-white rounded-xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition-shadow">
        <h3 class="font-bold text-brand-dark">NordVPN vs Surfshark</h3>
        <p class="text-sm text-gray-500 mt-1">Same parent company, different strengths</p>
      </a>
      <a href="/compare/expressvpn-vs-surfshark" class="block bg-white rounded-xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition-shadow">
        <h3 class="font-bold text-brand-dark">ExpressVPN vs Surfshark</h3>
        <p class="text-sm text-gray-500 mt-1">Premium vs Budget</p>
      </a>
      <a href="/compare/cyberghost-vs-nordvpn" class="block bg-white rounded-xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition-shadow">
        <h3 class="font-bold text-brand-dark">CyberGhost vs NordVPN</h3>
        <p class="text-sm text-gray-500 mt-1">Best for Beginners vs Best Overall</p>
      </a>
      <a href="/compare/protonvpn-vs-mullvad" class="block bg-white rounded-xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition-shadow">
        <h3 class="font-bold text-brand-dark">Proton VPN vs Mullvad</h3>
        <p class="text-sm text-gray-500 mt-1">Best Privacy VPNs</p>
      </a>
    </div>
  </div>
  <Footer slot="footer" />
</BaseLayout>
