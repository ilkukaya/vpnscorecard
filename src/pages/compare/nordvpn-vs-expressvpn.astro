---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTAButton from '../../components/CTAButton.astro';
import ProConList from '../../components/ProConList.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import { getVPNBySlug, getPricing } from '../../lib/vpnData';
import { getBestAffiliateLink, getCTAText } from '../../lib/affiliateLinks';
import { formatPrice } from '../../lib/formatters';

const vpn1 = getVPNBySlug('nordvpn');
const vpn2 = getVPNBySlug('expressvpn');
const pricing1 = getPricing('nordvpn');
const pricing2 = getPricing('expressvpn');
const link1 = getBestAffiliateLink(vpn1, 'compare');
const link2 = getBestAffiliateLink(vpn2, 'compare');
const winner = vpn1.puanlar.toplam >= vpn2.puanlar.toplam ? vpn1 : vpn2;
const loser = winner === vpn1 ? vpn2 : vpn1;

const title = 'NordVPN vs ExpressVPN 2026: Which is Better? [Speed Tested]';
const description = 'NordVPN wins on speed (887 vs 812 Mbps) and value ($3.09 vs $6.67/mo). ExpressVPN wins on RAM-only servers. Full comparison inside.';
---

<BaseLayout title={title} description={description}>
  <Header slot="header" />
  <AffiliateDisclosure />
  <div class="max-w-5xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-6">
      <ol class="flex items-center gap-1">
        <li><a href="/" class="hover:text-brand">Home</a></li>
        <li><span class="mx-1">/</span></li>
        <li><a href="/compare/" class="hover:text-brand">Compare</a></li>
        <li><span class="mx-1">/</span></li>
        <li class="text-gray-700">NordVPN vs ExpressVPN</li>
      </ol>
    </nav>
    <h1 class="text-3xl md:text-4xl font-bold text-brand-dark mb-2">NordVPN vs ExpressVPN: Which is Better in 2026?</h1>
    <p class="text-gray-600 mb-8">We tested both VPNs side by side. Here's the data-driven verdict.</p>
    <div class="bg-green-50 border border-green-200 rounded-xl p-6 mb-8">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-2xl">🏆</span>
        <h2 class="text-xl font-bold text-green-800">Winner: {winner.ad}</h2>
      </div>
      <p class="text-green-700">For most users, {winner.ad} offers better value with a score of {winner.puanlar.toplam}/100 vs {loser.puanlar.toplam}/100. {loser.ad} wins on: {loser.guvenlik.ram_only ? 'RAM-only servers' : 'specific features'}.</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-8">
      <h2 class="text-xl font-bold text-brand-dark mb-6">Head-to-Head Comparison</h2>
      <ComparisonTable vpns={[vpn1, vpn2]} pricing={{ nordvpn: pricing1, expressvpn: pricing2 }} pageType="compare" />
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h3 class="text-lg font-bold text-brand-dark mb-3">Choose {vpn1.ad} if:</h3>
        <ul class="space-y-2 text-gray-700">
          <li class="flex gap-2"><span class="text-green-500">✓</span> You want the fastest speeds (887 Mbps)</li>
          <li class="flex gap-2"><span class="text-green-500">✓</span> You need 10 simultaneous connections</li>
          <li class="flex gap-2"><span class="text-green-500">✓</span> Price matters ($3.09/mo vs $6.67/mo)</li>
          <li class="flex gap-2"><span class="text-green-500">✓</span> You want more countries (111 vs 105)</li>
        </ul>
        <CTAButton href={link1} vpnId={vpn1.id} pageType="compare" variant="primary" size="md" class="mt-4" fullWidth>Get {vpn1.ad}</CTAButton>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h3 class="text-lg font-bold text-brand-dark mb-3">Choose {vpn2.ad} if:</h3>
        <ul class="space-y-2 text-gray-700">
          <li class="flex gap-2"><span class="text-green-500">✓</span> You need RAM-only servers (TrustedServer)</li>
          <li class="flex gap-2"><span class="text-green-500">✓</span> Router setup is a priority</li>
          <li class="flex gap-2"><span class="text-green-500">✓</span> You prefer Lightway protocol</li>
          <li class="flex gap-2"><span class="text-green-500">✓</span> You want the most polished UX</li>
        </ul>
        <CTAButton href={link2} vpnId={vpn2.id} pageType="compare" variant="primary" size="md" class="mt-4" fullWidth>Get {vpn2.ad}</CTAButton>
      </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-8">
      <h2 class="text-xl font-bold text-brand-dark mb-4">Price Comparison</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="p-4 bg-slate-50 rounded-lg">
          <h3 class="font-bold text-brand-dark">{vpn1.ad}</h3>
          {pricing1 && Object.entries(pricing1).filter(([k]) => k.includes('plan')).map(([key, plan]: [string, any]) => (
            <p class="text-sm text-gray-600 mt-1">{key.replace(/_/g, ' ')}: ${plan.fiyat}/mo</p>
          ))}
        </div>
        <div class="p-4 bg-slate-50 rounded-lg">
          <h3 class="font-bold text-brand-dark">{vpn2.ad}</h3>
          {pricing2 && Object.entries(pricing2).filter(([k]) => k.includes('plan')).map(([key, plan]: [string, any]) => (
            <p class="text-sm text-gray-600 mt-1">{key.replace(/_/g, ' ')}: ${plan.fiyat}/mo</p>
          ))}
        </div>
      </div>
    </div>
    <div class="mb-8">
      <h2 class="text-xl font-bold text-brand-dark mb-4">Frequently Asked Questions</h2>
      <FAQAccordion questions={[
        { question: 'Is NordVPN faster than ExpressVPN?', answer: 'Yes. In our March 2026 tests, NordVPN reached 887 Mbps (NordLynx) vs ExpressVPN\'s 812 Mbps (Lightway). Both are excellent for 4K streaming.' },
        { question: 'Which is more private?', answer: 'Both have independently audited no-logs policies. ExpressVPN has an edge with RAM-only servers (TrustedServer), while NordVPN is based in Panama (outside 14 Eyes) vs ExpressVPN\'s British Virgin Islands.' },
        { question: 'Which is better value?', answer: 'NordVPN at $3.09/mo (2-year) vs ExpressVPN at $6.67/mo (1-year). NordVPN offers significantly better value for comparable performance.' },
        { question: 'Can both unblock Netflix?', answer: 'Yes, both reliably unblock Netflix US, UK, and most other regional libraries.' },
      ]} />
    </div>
  </div>
  <Footer slot="footer" />
</BaseLayout>
