---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTAButton from '../../components/CTAButton.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import { getVPNBySlug, getPricing } from '../../lib/vpnData';
import { getBestAffiliateLink } from '../../lib/affiliateLinks';

const vpn1 = getVPNBySlug('cyberghost');
const vpn2 = getVPNBySlug('nordvpn');
const pricing1 = getPricing('cyberghost');
const pricing2 = getPricing('nordvpn');
const link1 = getBestAffiliateLink(vpn1, 'compare');
const link2 = getBestAffiliateLink(vpn2, 'compare');
const title = 'CyberGhost vs NordVPN 2026: Best VPN for Beginners?';
const description = 'CyberGhost is easier to use and cheaper. NordVPN is faster and more private. Full comparison.';
---
<BaseLayout title={title} description={description}>
  <Header slot="header" />
  <AffiliateDisclosure />
  <div class="max-w-5xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-6"><ol class="flex items-center gap-1"><li><a href="/" class="hover:text-brand">Home</a></li><li><span class="mx-1">/</span></li><li><a href="/compare/" class="hover:text-brand">Compare</a></li><li><span class="mx-1">/</span></li><li class="text-gray-700">CyberGhost vs NordVPN</li></ol></nav>
    <h1 class="text-3xl md:text-4xl font-bold text-brand-dark mb-2">CyberGhost vs NordVPN: Best VPN for Beginners?</h1>
    <p class="text-gray-600 mb-8">CyberGhost is the easiest VPN. NordVPN is the best overall. Which is right for you?</p>
    <div class="bg-green-50 border border-green-200 rounded-xl p-6 mb-8">
      <div class="flex items-center gap-3 mb-2"><span class="text-2xl">🏆</span><h2 class="text-xl font-bold text-green-800">Winner: {vpn2.ad} ({vpn2.puanlar.toplam} vs {vpn1.puanlar.toplam})</h2></div>
      <p class="text-green-700">{vpn2.ad} wins overall. {vpn1.ad} wins on ease of use and price.</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-8">
      <ComparisonTable vpns={[vpn1, vpn2]} pricing={{ cyberghost: pricing1, nordvpn: pricing2 }} pageType="compare" />
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h3 class="text-lg font-bold text-brand-dark mb-3">Choose {vpn1.ad} if:</h3>
        <ul class="space-y-2 text-gray-700">
          <li class="flex gap-2"><span class="text-green-500">✓</span> You're new to VPNs</li>
          <li class="flex gap-2"><span class="text-green-500">✓</span> You want dedicated streaming servers</li>
          <li class="flex gap-2"><span class="text-green-500">✓</span> You want the lowest price ($2.03/mo)</li>
        </ul>
        <CTAButton href={link1} vpnId={vpn1.id} pageType="compare" variant="primary" size="md" class="mt-4" fullWidth>Get {vpn1.ad}</CTAButton>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h3 class="text-lg font-bold text-brand-dark mb-3">Choose {vpn2.ad} if:</h3>
        <ul class="space-y-2 text-gray-700">
          <li class="flex gap-2"><span class="text-green-500">✓</span> You want the fastest speeds</li>
          <li class="flex gap-2"><span class="text-green-500">✓</span> Privacy is your top priority</li>
          <li class="flex gap-2"><span class="text-green-500">✓</span> You want Threat Protection</li>
        </ul>
        <CTAButton href={link2} vpnId={vpn2.id} pageType="compare" variant="primary" size="md" class="mt-4" fullWidth>Get {vpn2.ad}</CTAButton>
      </div>
    </div>
    <FAQAccordion questions={[
      { question: 'Is CyberGhost easier to use than NordVPN?', answer: 'Yes. CyberGhost has dedicated server profiles for streaming and torrenting, making it the most beginner-friendly VPN we tested.' },
      { question: 'Which is faster?', answer: 'NordVPN (887 Mbps) is significantly faster than CyberGhost (743 Mbps) in our speed tests.' },
      { question: 'Is CyberGhost safe?', answer: 'Yes. CyberGhost has an independently audited no-logs policy by Deloitte and uses AES-256 encryption.' },
    ]} />
  </div>
  <Footer slot="footer" />
</BaseLayout>
