---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import QuizWidget from '../../components/QuizWidget';

const lang = 'tr';
const title = 'Hangi VPN Size Uygun? Testi Çözün | VPNScorecard';
const description = '5 hızlı soruyu yanıtlayın, ihtiyaçlarınıza en uygun VPN\'i önerelim.';
---
<BaseLayout title={title} description={description} lang={lang}>
  <Header slot="header" lang={lang} />
  <div class="max-w-2xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-brand-dark mb-2 text-center">Hangi VPN Size Uygun?</h1>
    <p class="text-gray-600 mb-8 text-center">5 hızlı soruyu yanıtlayın, size mükemmel VPN'i önerelim.</p>
    <QuizWidget client:load lang={lang} />
  </div>
  <Footer slot="footer" lang={lang} />
</BaseLayout>
