---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import blogPosts from '../../../../data/blog-posts.json';
import { getLocalizedPath } from '../../../i18n/index';

const lang = 'es';
const title = 'Blog VPN — Guías, Noticias y Análisis | VPNScorecard';
const description = 'Guías expertas sobre VPN, noticias y análisis. Aprende sobre tecnología VPN, privacidad y seguridad.';
---
<BaseLayout title={title} description={description} lang={lang}>
  <Header slot="header" lang={lang} />
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-brand-dark mb-2">Blog VPN</h1>
    <p class="text-gray-600 mb-8">Guías, noticias y análisis sobre tecnología VPN y privacidad en línea.</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {(blogPosts as any).posts.map((post: any) => (
        <a href={getLocalizedPath(`/blog/${post.slug}`, lang)} class="block bg-white rounded-xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition-shadow">
          <div class="flex items-center gap-2 text-xs text-gray-500 mb-3">
            <span class="capitalize bg-slate-100 px-2 py-0.5 rounded">{post.category}</span>
            <span>{post.readTime} min de lectura</span>
          </div>
          <h2 class="font-bold text-brand-dark mb-2">{post.title}</h2>
          <p class="text-sm text-gray-600">{post.description}</p>
        </a>
      ))}
    </div>
  </div>
  <Footer slot="footer" lang={lang} />
</BaseLayout>
