---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import VPNCard from '../../components/VPNCard.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import { getStreamingVPNs, getPricing } from '../../lib/vpnData';

const vpns = getStreamingVPNs().filter(v => v.streaming.netflix_us);
const title = 'Best VPN for Netflix in 2026: Works with All Libraries';
const description = 'The best VPNs that reliably unblock Netflix US, UK, Japan, and more regional libraries.';
---
<BaseLayout title={title} description={description}>
  <Header slot="header" />
  <AffiliateDisclosure />
  <div class="max-w-5xl mx-auto px-4 py-8">
    <h1 class="text-3xl md:text-4xl font-bold text-brand-dark mb-2">Best VPN for Netflix in 2026</h1>
    <p class="text-gray-600 mb-8">These VPNs reliably unblock Netflix US, UK, Japan, and more regional libraries.</p>
    <div class="space-y-4 mb-8">
      {vpns.map((vpn, i) => { const pricing = getPricing(vpn.id); return <VPNCard vpn={vpn} rank={i + 1} pricing={pricing} pageType="best-netflix" />; })}
    </div>
    <FAQAccordion questions={[
      { question: 'Why doesn\'t my VPN work with Netflix?', answer: 'Netflix actively blocks VPN IP addresses. Only VPNs with large, rotating server pools can consistently bypass these blocks.' },
      { question: 'Can I watch Netflix UK with a VPN?', answer: 'Yes. NordVPN, ExpressVPN, and Proton VPN all reliably unblock Netflix UK.' },
      { question: 'Will Netflix ban my account for using a VPN?', answer: 'No. Netflix may show a proxy error, but they don\'t ban accounts for VPN use.' },
    ]} />
  </div>
  <Footer slot="footer" />
</BaseLayout>
